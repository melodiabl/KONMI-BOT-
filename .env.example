# Environment
NODE_ENV=production

# Server Configuration
PORT=3001

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Owner WhatsApp number (digits only)
OWNER_WHATSAPP_NUMBER=1234567890

# Token shared with sub-bots for event authentication
SUBBOT_EVENT_TOKEN=change-this-token

# Gemini AI configuration
GEMINI_API_KEY=your-gemini-api-key

# Database Configuration (SQLite is used by default)
DATABASE_PATH=./backend/full/storage/database.sqlite

# CORS Configuration
FRONTEND_URL=https://your-app-name.railway.app
RAILWAY_STATIC_URL=https://your-app-name.railway.app

# WhatsApp Bot Configuration
BOT_NAME=WhatsApp Bot Panel
BOT_VERSION=2.5

# Admin User (will be created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Railway specific
RAILWAY_ENVIRONMENT=production
